# Local dashboard environment example.
# Copy to config/dashboard.env and edit locally. The copied file is ignored.

AGENT_PANEL_MOCK_GATEWAY=0
AGENT_PANEL_OLED_MODE=ssd1322
AGENT_PANEL_OLED_ROTATION=180
AGENT_PANEL_USE_EVDEV_CONTROLS=1
AGENT_PANEL_DEFAULT_AGENT=default
AGENT_PANEL_LOG_LEVEL=INFO

# Default gateway uses loopback. If AGENT_PANEL_GATEWAY_URL is set explicitly,
# also set OPENCLAW_GATEWAY_TOKEN or OPENCLAW_GATEWAY_PASSWORD.
# AGENT_PANEL_GATEWAY_URL=ws://127.0.0.1:18789/ws
# OPENCLAW_GATEWAY_TOKEN=<OPENCLAW_GATEWAY_TOKEN>
# OPENCLAW_GATEWAY_PASSWORD=<OPENCLAW_GATEWAY_PASSWORD>

# Optional explicit evdev devices if auto-detection fails.
# AGENT_PANEL_ENC_MAIN_EVDEV_DEVICE=/dev/input/eventX
# AGENT_PANEL_ENC_LEFT_EVDEV_DEVICE=/dev/input/eventY
# AGENT_PANEL_ENC_RIGHT_EVDEV_DEVICE=/dev/input/eventZ
# AGENT_PANEL_BTN_EVDEV_DEVICE=/dev/input/eventN

# Optional GPIO fallback if evdev overlays are not used.
# AGENT_PANEL_BTN_LEFT_PIN=24
# AGENT_PANEL_BTN_ENTER_PIN=25
# AGENT_PANEL_BTN_RIGHT_PIN=23
# AGENT_PANEL_ENC_MAIN_PINS=5:6
# AGENT_PANEL_ENC_LEFT_PINS=13:12
# AGENT_PANEL_ENC_RIGHT_PINS=27:22
