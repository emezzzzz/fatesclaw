# Local OpenClaw environment example.
# Copy to config/openclaw.env and edit locally. The copied file is ignored.

OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=<OPENCLAW_GATEWAY_TOKEN>

# Optional provider example. Keep real provider keys out of git.
NVIDIA_API_KEY=<YOUR_NVIDIA_API_KEY>
OPENCLAW_DEFAULT_PROVIDER=nvidia
OPENCLAW_DEFAULT_MODEL=<NVIDIA_MODEL_NAME>
