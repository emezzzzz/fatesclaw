# NVIDIA provider example for OpenClaw.
# Copy values into an ignored local env file. Never commit real keys.

NVIDIA_API_KEY=<YOUR_NVIDIA_API_KEY>
OPENCLAW_DEFAULT_PROVIDER=nvidia
OPENCLAW_DEFAULT_MODEL=<NVIDIA_MODEL_NAME>

# Example model placeholders:
# OPENCLAW_DEFAULT_MODEL=nvidia/<MODEL_NAME>
# OPENCLAW_DEFAULT_MODEL=meta/llama-3.1-70b-instruct
